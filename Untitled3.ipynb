      "source": [
        "unit=int(input())\n",
        "if unit<100:\n",
        "  bill=0\n",
        "elif unit>=200:\n",
        "  bill=(unit-100)*5\n",
        "elif unit>=300:\n",
        "  bill=(100*5)+(unit-200)*7\n",
        "elif unit>=400:\n",
        "  bill=(100*5)+(100*7)+(unit-300)*10\n",
        "print('electricity bill:',bill)"
      ]
    }
  ]
}