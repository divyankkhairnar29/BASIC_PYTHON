      "source": [
        "km=int(input())\n",
        "waiting=int(input())\n",
        "if km < 100:\n",
        "  meter=10*km\n",
        "elif km <200:\n",
        "  meter=(100*10)+(km-200)*9\n",
        "elif km < 800:\n",
        "  meter=(100*10)+(km-200)*6\n",
        "meter+=waiting*5\n",
        "print(\"Auto meter:\",meter)"
      ]
