      "source": [
        "n = int(input(\"Enter a number: \"))\n",
        "if n < 0:\n",
        "    n = -(n)\n",
        "reverse_number = int(str(n)[::-1])\n",
        "print(\"Reversed Number:\", reverse_number)"
